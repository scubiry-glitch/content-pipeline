# =============================================================================
# 内容生产流水线 - 环境变量配置
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API Keys (至少配置一个，推荐使用 Dashboard LLM 或 Kimi)
# -----------------------------------------------------------------------------

# Dashboard LLM API - 推荐，通过 Dashboard 接入 LLM
# 优先级最高，配置了此选项将优先使用 Dashboard LLM
LLM_API_TOKEN=your_dashboard_llm_token_here
LLM_API_BASE_URL=http://127.0.0.1:3004
DASHBOARD_LLM_MODEL=k2p5

# Kimi API (Moonshot) - 备用选项
# 获取地址: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# Claude API (Anthropic) - 备用选项
# 获取地址: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI API - 用于 Embedding 和备用
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# SiliconFlow API - DeepSeek/Qwen 模型
# 获取地址: https://cloud.siliconflow.cn/
# SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# 火山引擎 (豆包) API - DeepSeek 模型 + web_search 等工具
# 获取地址: https://console.volcengine.com/
# VOLCANO_API_KEY=your_volcano_api_key_here
# VOLCANO_MODEL=deepseek-v3-2-251201

# === 模型统一配置 ===
# 全局默认主模型 (影响 llm.ts generate 函数和素材库处理)
# DEFAULT_LLM_MODEL=kimi-for-coding

# 强制禁用 Kimi (即使配置了 KIMI_API_KEY)
# USE_KIMI=false

# -----------------------------------------------------------------------------
# Web Search API Keys (用于深度研究，可选但推荐)
# -----------------------------------------------------------------------------

# Tavily API - 推荐的研究型搜索引擎
# 获取地址: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Serper.dev API - Google 搜索 API
# 获取地址: https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL with pgvector)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=content_pipeline
DB_USER=postgres
DB_PASSWORD=your_password_here

# 或者使用 DATABASE_URL
# DATABASE_URL=postgresql://user:password@localhost:5432/content_pipeline

# -----------------------------------------------------------------------------
# Authentication (MVP: single user API key)
# -----------------------------------------------------------------------------
ADMIN_API_KEY=dev-api-key-change-in-production

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Wiki vault root (统一所有 wiki 写入路径)
# -----------------------------------------------------------------------------
# 默认 <repo-root>/data/content-wiki/default
# 优先级: MN_CLAUDE_WIKI_ROOT > CONTENT_LIBRARY_WIKI_ROOT > WIKI_ROOT > 默认
# 推荐新项目只 set WIKI_ROOT
# WIKI_ROOT=/abs/path/to/wiki/vault

# -----------------------------------------------------------------------------
# Meeting-notes RunQueue
# -----------------------------------------------------------------------------
# heartbeat-timeout 阈值 (分钟): claude-cli + opus 单 run 7-10min, 默认 15 min
# MN_HEARTBEAT_STALE_MIN=15

# -----------------------------------------------------------------------------
# 配置检查
# -----------------------------------------------------------------------------
# 启动时会检查以下配置:
# 1. LLM API: 至少需要一个 (LLM_API_TOKEN, KIMI_API_KEY, CLAUDE_API_KEY, 或 OPENAI_API_KEY)
#    优先级: LLM_API_TOKEN > KIMI_API_KEY > CLAUDE_API_KEY > OPENAI_API_KEY
# 2. 数据库: PostgreSQL with pgvector 扩展
# 3. 搜索 API (可选): TAVILY_API_KEY 或 SERPER_API_KEY
#
# 如果没有配置 LLM API，系统将抛出错误并拒绝启动
