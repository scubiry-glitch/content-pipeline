# ============================================
# v6.2 Assets AI - Embedding 配置示例
# 复制此文件为 .env 并根据需要修改
# ============================================

# ============================================
# 方式1: SiliconFlow (生产环境推荐) ⭐
# ============================================
# 特点:
#   - 中文 Embedding 效果最佳
#   - 实测相似度: 0.75-0.77 (同类文本)
#   - 速度: 单文本 ~300ms，批量 ~60ms/文本
#   - 价格: 性价比高
#
# 申请地址: https://siliconflow.cn/
# 支持模型:
#   - netease-youdao/bce-embedding-base_v1 (推荐，768维)
#   - BAAI/bge-large-zh-v1.5 (1024维)
#   - BAAI/bge-m3 (1024维，多语言)

SILICONFLOW_API_KEY=sk-your-siliconflow-api-key
embedding_model=netease-youdao/bce-embedding-base_v1

# ============================================
# 方式2: OpenAI (备选方案)
# ============================================
# 特点:
#   - 英文优化，效果优秀
#   - 1536维向量
#   - 价格相对较高

# OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# 方式3: Dashboard LLM (复用现有配置)
# ============================================
# 特点:
#   - 无需额外 API Key
#   - 使用现有 LLM 配置
#   - 速度较慢 (2-3s/文本)
#   - 效果一般 (基于 LLM 语义提取)
#
# 注意: 如果已配置 KIMI_API_KEY，可复用

DASHBOARD_LLM_MODEL=k2p5
# LLM_API_TOKEN=sk-your-token  # 可选，默认为 KIMI_API_KEY
LLM_API_BASE_URL=http://127.0.0.1:3006

# ============================================
# 其他 LLM 配置 (用于 AI 分析)
# ============================================
KIMI_API_KEY=sk-your-kimi-api-key

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/pipeline
# 或分开配置
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pipeline
# DB_USER=postgres
# DB_PASSWORD=your-password

# ============================================
# API 认证
# ============================================
ADMIN_API_KEY=your-admin-api-key
