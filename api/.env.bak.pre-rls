# ===== 启动性能开关（v7.7）=====
# false: 仅做数据库连通性检查（推荐日常开发）
# true: 启动时执行全量 schema/migration（仅在你明确要迁移时打开）
DB_AUTO_MIGRATE=false

# false: 跳过启动时 taxonomy 全量同步，减少首屏竞争
TAXONOMY_BOOTSTRAP=false

# 后台任务错峰启动间隔（毫秒）
STARTUP_TASK_STAGGER_MS=15000

# 目录监听（高负载，默认关闭）
DIRECTORY_WATCHER_ENABLED=false

# -----------------------------------------------------------------------------
# Wiki vault root · 所有写 wiki 的代码点共用
# -----------------------------------------------------------------------------
# 默认 <repo-root>/data/content-wiki/default
# 优先级: MN_CLAUDE_WIKI_ROOT > CONTENT_LIBRARY_WIKI_ROOT > WIKI_ROOT > 默认
# 留空 = 走默认 (推荐保持空, 跟 git 仓库 data/content-wiki/default 同步)
WIKI_ROOT=data/content-wiki/default

# -----------------------------------------------------------------------------
# Meeting-notes RunQueue
# -----------------------------------------------------------------------------
