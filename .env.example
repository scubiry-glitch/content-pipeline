# Content Pipeline API - 环境变量配置
# 复制此文件为 .env 并填入你的配置

# ============================================================
# LLM API Keys（至少配置一个）
# ============================================================

# Kimi (Moonshot) - 首选
KIMI_API_KEY=sk-kimi-xxx
KIMI_BASE_URL=https://api.kimi.com/coding

# Claude (Anthropic) - 备选
CLAUDE_API_KEY=sk-ant-api03-xxx

# OpenAI - 备选
OPENAI_API_KEY=sk-proj-xxx

# ============================================================
# 数据库配置
# ============================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=author
DB_USER=author
DB_PASSWORD=your_secure_password

# 或者使用完整连接字符串
DATABASE_URL=postgresql://author:your_secure_password@localhost:5432/author

# ============================================================
# 认证配置
# ============================================================

# API 访问密钥（重要！生产环境务必修改）
ADMIN_API_KEY=dev-api-key-change-in-production

# ============================================================
# 服务器配置
# ============================================================

PORT=3000
NODE_ENV=development

# ============================================================
# 可选：代理配置（如需要）
# ============================================================

# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
