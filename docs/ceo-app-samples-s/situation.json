  "$ui_signal_lifecycle": {
    "$desc": "外部信号 life-cycle — 抓取 → 评分 → 归档",
    "steps": [
      {
        "step": 1,
        "name": "抓取",
        "trigger": "cron · 每 6 小时",
        "source": "RSS feeds + 邮件转发箱 + 手动 paste",
        "writes": "ceo_external_signals.signal_text + source_url + captured_at"
      },
      {
        "step": 2,
        "name": "归类",
        "trigger": "LLM g3 · 信号入库即触发",
        "rule": "Claude 提取 stakeholder_kind + sentiment ∈ [-1, 1] + category ∈ {pos/neu/neg}",
        "writes": "ceo_external_signals.sentiment + 写入 mn_runs(module='ceo', axis='g3', metadata.kind='signal-classify')"
      },
      {
        "step": 3,
        "name": "回应草稿",
        "trigger": "LLM g3 · sentiment < -0.4 OR LP/board kind",
        "rule": "Claude 生成 1 句话回应建议 + 关联 asset/sandbox",
        "writes": "auto_response_suggested (内存 / 临时缓存)"
      },
      {
        "step": 4,
        "name": "盲点检测",
        "trigger": "cron · 每日 03:00",
        "rule": "规则引擎 + LLM 双轨 — 检查 4 条盲点规则",
        "writes": "blindspots view 即时返回, 不持久化"
      },
      {
        "step": 5,
        "name": "归档",
        "trigger": "cron · 每月 1 日",
        "rule": "captured_at > 90d AND sentiment 已被引用 AND 无新信号",
        "writes": "ceo_external_signals.archived_at"
      }
    ]
  },
  "$aggregator": {
    "coverage": "已覆盖 stakeholder kind / 5 必备 (customer/regulator/investor/press/partner)",
    "calc": "DISTINCT(kind) ⊇ REQUIRED_KINDS → 5/5",
    "rubric_avg": "AVG(scores[d].value) for d in dimensions, exclude N/A",
    "$note": "employee 不在 REQUIRED_KINDS 但 demo 含 8 类 stakeholders 让数据更丰富 (demo.sql 行 84-95)"
  },
