          "metric": {
            "label": "覆盖度",
            "value": "5/5",
            "delta_vs_last_week": "→",
            "target": "5/5",
            "tooltip_explanation": "覆盖度 = DISTINCT(stakeholder.kind) ⊇ {customer/regulator/investor/press/partner} · 6 类全覆盖"
