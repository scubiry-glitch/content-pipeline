          "room": "Compass",
          "metric": {
            "label": "战略对齐度",
            "value": "0.72",
            "delta_vs_last_week": "+0.04",
            "target": 0.8,
            "tooltip_explanation": "对齐度 = AVG(ceo_strategic_lines.alignment_score WHERE status='active') · 当前 6 主线均值 0.72, 距 0.80 目标 0.08"
          },
          "sector": {
            "source": "历史纪要",
            "step": "跨会联动",
            "output": "一页纸摘要",
            "app": "战略对齐度 / 破坏浣熊"
