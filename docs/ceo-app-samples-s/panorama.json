{
  "$comment": "Panorama · 全景画板样例 — 单端点聚合 6 棱镜 + 5 步骤组 + 4 源 + 12 产出 · 三视图共享一份数据",
  "$page": "/ceo/internal/ceo/panorama",
  "$prototype": "07-archive/会议纪要 (20260501)/panorama.jsx",
  "$question": "一份会议, 如何变成 6 个房间 / 一年的积累?",
  "endpoints": {
    "GET /api/v1/ceo/panorama": {
      "$desc": "三视图共享数据源 · /panorama 一次拉, FurnaceView/TimelineView/IcebergView 各自渲染",
      "prisms": [
        {
          "id": "direction",
          "icon": "🧭",
