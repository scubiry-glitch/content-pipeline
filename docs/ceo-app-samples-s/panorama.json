  "$aggregator": {
    "$desc": "Panorama 单端点并行调 6 房间 aggregator + mn_runs 计数",
    "parallel_calls": [
      {
        "fn": "computeAlignmentScore",
        "from": "rooms/compass/aggregator",
        "writes_to": "metricByPrism.direction.value"
      },
      {
        "fn": "computeForwardPct",
        "from": "rooms/boardroom/aggregator",
        "writes_to": "metricByPrism.board.value"
      },
      {
        "fn": "computeResponsibilityClarity",
        "from": "rooms/tower/aggregator",
        "writes_to": "metricByPrism.coord.value"
      },
      {
        "fn": "computeFormationHealth",
        "from": "rooms/war-room/aggregator",
