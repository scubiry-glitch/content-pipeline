        },
        {
          "id": "board",
          "icon": "🏛️",
          "label": "董事会",
          "color": "#C8A15C",
          "tint": "rgba(200,161,92,0.07)",
          "room": "Boardroom",
          "metric": {
            "label": "前瞻占比",
            "value": "58%",
            "delta_vs_last_week": "+3pp",
            "target": "60%",
            "tooltip_explanation": "前瞻占比 = (前瞻议题 / 全部议题) — 5 位董事 12 项关切中 7 项 forward-looking"
          },
          "sector": {
            "source": "专家库",
            "step": "外脑批注",
            "output": "外脑批注资产",
            "app": "董事关切雷达 / 预读包"
          }
        },
        {
          "id": "coord",
          "icon": "🎯",
          "label": "协调",
          "color": "#7FD6A0",
          "tint": "rgba(127,214,160,0.07)",
          "room": "Tower",
          "metric": {
            "label": "责任清晰度",
            "value": "78%",
            "delta_vs_last_week": "-2pp",
            "target": "85%",
            "tooltip_explanation": "责任清晰度 = (有明确 owner+due+criteria 的承诺 / 全部承诺) — 47 条 mn_commitments 中 37 条三要素齐"
          },
          "sector": {
            "source": "会议原材料",
            "step": "实体 & 承诺抽取",
            "output": "承诺清单",
            "app": "责任盘点 / 会后 10 分钟卡"
          }
        },
        {
          "id": "team",
          "icon": "⚔️",
          "label": "团队",
          "color": "#E6A6A6",
          "tint": "rgba(230,166,166,0.07)",
          "room": "War Room",
          "metric": {
            "label": "阵型健康",
            "value": "72",
            "delta_vs_last_week": "-4",
            "target": 80,
            "tooltip_explanation": "阵型健康 = 100 - W·sum(silence_signals) - W·sum(judgment_dissent) — 本周陆景行沉默 + Wei/Omar 评分分歧导致 -4"
          },
          "sector": {
            "source": "会议原材料",
