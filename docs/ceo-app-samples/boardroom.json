            { "type": "asset",   "id": "asset-crucible-3w-rule", "title": "3 周失联法则 v2" }
          ],
          "created_at": "2026-04-12T11:00:00Z"
        },
        {
          "id": "ann-uuid-004",
          "expert_id": "lp-coach-v1",
