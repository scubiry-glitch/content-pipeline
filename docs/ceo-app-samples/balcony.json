  "$cron_behavior": {
    "$comment": "周日 21:00 自动生成下周反思问句 — Sunday 21:00 cron",
    "schedule": "0 21 * * 0",
    "axis": "g3",
    "module": "ceo",
    "task_type": "balcony_reflection_generate",
    "ranBy": "system",
    "logic": [
      "step_1: SELECT * FROM ceo_prisms WHERE scope_id IS NULL ORDER BY computed_at DESC LIMIT 1",
      "step_2: 排序找到 weakest 棱镜（本周 = self 0.41）",
      "step_3: 排序找到 涨幅最大的棱镜（本周 = coord +0.06）",
      "step_4: 排序找到 跌幅最大的棱镜（本周 = self -0.12，4 周连续）",
      "step_5: 选 3 个棱镜生成 3 个反思问句 — direction（每周固定）+ team（涨/跌最大优先）+ self（必带 weakest）",
      "step_6: 每个问句调 g3 LLM，prompt = 'minutes 引用 + 张力图 + silence_signals 数据点 → 1 句问 + 1 段引子'",
      "step_7: INSERT INTO ceo_balcony_reflections (user_id, week_start, prism_id, question, prompt, run_id)"
    ],
    "$question_priority_rules": {
      "direction": "默认每周 1 题（基于本周最大决策 — 从 mn_decisions 拉权重最高的）",
      "team":      "若本周有 person 沉默/发言比变化 ≥2x → team 题；否则 board / ext 轮换",
      "self":      "若 self 棱镜 4 周连续下降 OR <0.45 → 必带 self 题",
      "$current_week_picked": "direction (默认) + team (周劭然 11.8 触发) + self (0.41 触发)"
    },
    "fallback_if_llm_fails": "回退 fixture 3 题（保证周日永远有问句呈现，不能空白）"
  },
