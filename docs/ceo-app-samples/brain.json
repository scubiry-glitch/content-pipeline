  "$sse_endpoint": {
    "$desc": "R3-2 · 单 run 实时进度流 — text/event-stream",
    "endpoint": "GET /api/v1/ceo/runs/:runId/stream",
    "headers": {
      "Content-Type": "text/event-stream",
      "Cache-Control": "no-cache",
      "X-Accel-Buffering": "no"
    },
    "example_event_sequence": [
      { "event": "snapshot", "data": { "id": "bbbbbbbb-0003-...", "state": "running", "progress_pct": 12, "metadata": { "currentStep": "g3 · 沙盘 · 加载 branches" } } },
      { "event": "progress", "data": { "progress_pct": 24, "currentStep": "g3 · 沙盘 · 评估 branch r0-a" } },
      { "event": "progress", "data": { "progress_pct": 38, "currentStep": "g3 · 沙盘 · 评估 branch r0-a-1", "llmCalls": 2 } },
      { "event": "progress", "data": { "progress_pct": 62, "currentStep": "g3 · 沙盘 · 评估 branch r0-b", "llmCalls": 4 } },
      { "event": "progress", "data": { "progress_pct": 84, "currentStep": "g3 · 沙盘 · 写入 evaluation", "llmCalls": 7 } },
      { "event": "done",     "data": { "state": "succeeded", "progress_pct": 100, "cost_tokens": 22400, "cost_ms": 272000 } }
    ],
    "$polling_fallback": "若 EventSource 不可用 (旧浏览器 / 代理截流), 前端降级为 8 秒 polling /api/v1/ceo/brain/tasks?ids=<runId>",
    "$keep_alive": "服务端每 25s 发一条 ': keep-alive\\n\\n' 注释行, 防止代理 60s 超时"
  },

  "$llm_adapter": {
    "$desc": "R3-6 · CEO LLM Adapter — 复用 mn 的 LlmHandle, 多 provider 解析",
    "source": "api/src/modules/ceo/adapters/llm.ts",
    "providers": [
      { "id": "claude", "name": "Claude (Sonnet/Opus)", "transport": "claudeCli (本地 binary)", "fallbackOrder": 1, "isAvailable": "ANTHROPIC 凭证 OR CLAUDE_CLI_PATH 存在" },
      { "id": "kimi",   "name": "Kimi (Moonshot)",      "transport": "HTTP API (KIMI_API_KEY)", "fallbackOrder": 2, "isAvailable": "process.env.KIMI_API_KEY 非空" },
      { "id": "openai", "name": "OpenAI (gpt-4)",       "transport": "HTTP API (OPENAI_API_KEY)", "fallbackOrder": 3, "isAvailable": "process.env.OPENAI_API_KEY 非空" }
    ],
    "resolution_order": [
      "1. avail = handle.available() → { kimi, claude, openai } 三 boolean",
      "2. if avail.claude → handle.generateWithClaude(prompt) — 优先 (本地 cli, 0 网络成本)",
      "3. else if avail.kimi → handle.generateWithKimi(prompt)",
      "4. else if avail.openai → handle.generateWithOpenAI(prompt)",
      "5. else throw '[CeoLLM] no provider available'"
    ],
    "$coverage_axis": {
      "g1": { "real_llm": false, "reason": "ASR + 实体抽取走 mn 内部 step, CEO 不直接调 LLM" },
      "g2": { "real_llm": true,  "providers_used": ["claude"], "preset_minutes": "standard 2.3 min" },
      "g3-rebuttal": { "real_llm": true,  "providers_used": ["claude"], "preset_minutes": "standard 4.5 min" },
      "g3-sandbox":  { "real_llm": true,  "providers_used": ["claude"], "preset_minutes": "deep 12.0 min", "$note": "branch evaluation 需多轮调用" },
      "g4": { "real_llm": true,  "providers_used": ["claude"], "preset_minutes": "standard 1.8 min" },
      "g5": { "real_llm": false, "reason": "stub — 算 6 房间 aggregator 数学, 不调 LLM (R3-6 之后会接 narrative-gen LLM)" }
    },
    "$stub_mode": "环境无任何 provider 时, ceo 模块仍可启动 — runHandlers 走 stub 分支 (return random scores), 标记 metadata.llmProvider='stub'",
    "$cost_breakdown_14d": {
      "claude": { "calls": 38, "tokens": 2540000, "ms": 168400 },
      "kimi":   { "calls":  6, "tokens":   180000, "ms":  12800 },
      "openai": { "calls":  3, "tokens":   122000, "ms":   3300 }
    }
  },

