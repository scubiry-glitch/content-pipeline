      "$indexes": ["(module, state, created_at DESC)", "(scope_kind, scope_id)", "(axis)"],
      "module_distribution": {
        "mn":  "复用现有 axis 重算 (people/projects/knowledge/longitudinal/meta/all)",
        "ceo": "g1..g5 加工步骤, 由 PR12 CeoRunQueue 拉取执行"
